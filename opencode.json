{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/ai/coding-standards.md",
    "docs/ai/architecture.md",
    "docs/ai/project-context.md",
    "docs/ai/commands.md",
    ".trae/rules/project_rules.md"
  ],
  "command": {
    "/test": {
      "template": "./vendor/bin/phpunit",
      "description": "Run PHPUnit tests",
      "agent": "build"
    },
    "/stan": {
      "template": "./vendor/bin/phpstan analyse",
      "description": "Run PHPStan static analysis"
    },
    "/lint": {
      "template": "./vendor/bin/php-cs-fixer fix --dry-run --diff",
      "description": "Check PHP lint"
    },
    "/migrate": {
      "template": "php artisan migrate",
      "description": "Run database migrations"
    },
    "/tinker": {
      "template": "php artisan tinker",
      "description": "Open Laravel Tinker"
    }
  },
  "agent": {
    "general": {
      "steps": 30
    },
    "explore": {
      "steps": 15
    }
  },
  "skills": {
    "paths": [".opencode/skills", ".trae/skills"]
  },
  "formatter": {
    "php": {
      "command": ["./vendor/bin/pint"],
      "extensions": ["php"]
    }
  },
  "tool_output": {
    "max_lines": 5000,
    "max_bytes": 150000
  },
  "compaction": {
    "auto": true,
    "tail_turns": 4
  },
  "permission": {
    "bash": {
      "composer *": "allow",
      "php artisan *": "allow",
      "git *": "allow",
      "graphify *": "allow",
      "*": "ask"
    },
    "edit": "allow",
    "external_directory": {
      "~/.claude/skills/**": "allow",
      "~/.agents/skills/**": "allow",
      "../Package/sp-jwt-auth/**": "allow",
      "*": "ask"
    }
  },
  "mcp": {
    
  }
}
