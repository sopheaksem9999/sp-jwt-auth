{
  "name": "sopheak/sp-jwt-auth",
  "description": "JWT authentication for Laravel apps.",
  "type": "library",
  "license": "proprietary",
  "version": "0.1.10",
  "require": {
    "php": "^8.2|^8.3|^8.4|^8.5",
    "laravel/framework": "^12.0|^13.0",
    "nesbot/carbon": "^2.0|^3.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.92",
    "larastan/larastan": "^3.0",
    "phpstan/phpstan": "2.1.32",
    "orchestra/testbench": "^10.0|^11.0",
    "phpunit/phpunit": "^10.0|^11.0",
    "rector/rector": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Sopheak\\Core\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Sopheak\\Core\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
    "analyse": "vendor/bin/phpstan analyse src tests",
    "docs:validate": "php bin/validate-docs.php",
    "format": "@rector:fix",
    "format-check": "@rector:check",
    "rector": "vendor/bin/rector process --dry-run",
    "rector:fix": "vendor/bin/rector process",
    "rector:check": "vendor/bin/rector process --dry-run --no-progress-bar",
    "quality": [
      "@format-check",
      "@analyse",
      "@test"
    ]
  },
  "suggest": {},
  "extra": {
    "laravel": {
      "providers": [
        "Sopheak\\Core\\CoreSpLaravelApiProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
